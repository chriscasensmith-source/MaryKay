# Postgres connection string (from Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Passcode for the /admin page — pick something private
ADMIN_PASSCODE="change-me"

# Resend API key (https://resend.com)
RESEND_API_KEY="re_..."

# Optional: the "from" address for emails. Must be a verified domain in Resend.
# If unset, falls back to Resend's test sender (onboarding@resend.dev),
# which can only deliver to your own Resend account email.
RESEND_FROM="R3 Tour Team <tours@yourdomain.com>"

# Public URL of the deployed app, used to build links inside emails.
# No trailing slash.
APP_URL="http://localhost:3000"

# Timezone that slot dates/times are entered and displayed in.
# Set this on Render too, so emails and pages show the right local time.
TZ="America/Chicago"
